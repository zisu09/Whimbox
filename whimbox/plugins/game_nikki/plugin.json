{
  "id": "game_nikki",
  "name": "无限暖暖任务插件",
  "version": "0.1.0",
  "author": "whimbox",
  "description": "无限暖暖游戏的任务工具集合",
  "entry": "main.py",
  "api_version": "1.0",
  "min_core_version": "0.0.0",
  "permissions": ["screen", "input"],
  "tools": [
    {
      "id": "nikki.jihua",
      "name": "素材激化",
      "description": "素材激化：消耗活跃能量，用材料换取噗灵、丝线、闪亮泡泡",
      "input_schema": {
        "type": "object",
        "properties": {
          "target_material": { 
            "type": "string",
            "description": "可选。不传时会使用一条龙配置中的设置"
          },
          "cost_material": { 
            "type": "string",
            "description": "可选。不传时会使用一条龙配置中的设置"
          }
        },
        "required": []
      },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.bless",
      "name": "获取祝福闪光",
      "description": "消耗活跃能量，获取祝福闪光",
      "input_schema": {
        "type": "object",
        "properties": { "level_name": { "type": "string" } },
        "required": []
      },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.monster",
      "name": "魔物试炼",
      "description": "消耗活跃能量，挑战魔物试炼幻境",
      "input_schema": {
        "type": "object",
        "properties": { "level_name": { "type": "string" } },
        "required": []
      },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.dig",
      "name": "美鸭梨挖掘",
      "description": "美鸭梨挖掘，只有当明确说明“挖掘”或“美鸭梨挖掘”时才能调用这个工具",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.zhaoxi",
      "name": "完成朝夕心愿（大世界日常任务）",
      "description": "完成朝夕心愿（大世界日常任务）",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.search_path",
      "name": "搜索跑图路线",
      "description": "根据路线名、素材目标、获取方式，搜索候选路线，用于全自动采集、捕虫、清洁、钓鱼、刷噗灵等各类游戏行为",
      "input_schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "description": "路线名关键词，支持模糊匹配" },
          "target": { "type": "string", "description": "目标素材名，支持模糊匹配" }
        },
        "required": []
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "status": { "type": "string" },
          "message": { "type": "string" },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path_name": { "type": "string" }
              }
            }
          }
        }
      }
    },
    {
      "id": "nikki.load_path",
      "name": "运行指定跑图路线",
      "description": "运行指定的跑图路线",
      "input_schema": {
        "type": "object",
        "properties": { "path_name": { "type": "string", "description": "路线名" } },
        "required": ["path_name"]
      },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.record_path",
      "name": "录制跑图路线",
      "description": "录制跑图路线",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.record_macro",
      "name": "录制宏",
      "description": "录制键鼠宏",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.run_macro",
      "name": "运行宏",
      "description": "运行指定的宏",
      "input_schema": {
        "type": "object",
        "properties": { "macro_name": { "type": "string", "description": "宏名称" } },
        "required": ["macro_name"]
      },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.play_music",
      "name": "演奏音乐",
      "description": "演奏指定的乐谱",
      "input_schema": {
        "type": "object",
        "properties": { "macro_name": { "type": "string", "description": "乐谱名称" } },
        "required": ["macro_name"]
      },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.open_path_folder",
      "name": "打开脚本文件夹",
      "description": "打开存放脚本的文件夹",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" } } }
    },
    {
      "id": "nikki.daily_photo",
      "name": "简单拍照",
      "description": "简单拍照，用于完成每日任务",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.all_in_one",
      "name": "一条龙",
      "description": "一条龙，一次性完成所有任务",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.start_game",
      "name": "打开游戏",
      "description": "自动帮用户打开游戏",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.goto_ui",
      "name": "前往游戏的指定界面",
      "description": "前往游戏的指定界面",
      "input_schema": {
        "type": "object",
        "properties": { "page_name": { "type": "string", "description": "界面名称，只支持输入：主界面，地图，美鸭梨，活动大厅，换装" } },
        "required": ["page_name"]
      },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.monthly_pass",
      "name": "临取奇迹之旅（大月卡）奖励",
      "description": "领取奇迹之旅（大月卡）奖励",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.weekly_realm",
      "name": "完成周本",
      "description": "完成每周幻境（周本/心之突破幻境）",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.xinghai",
      "name": "完成星海拾光（星海日常任务）",
      "description": "完成星海拾光（星海日常任务）",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.mira_crown",
      "name": "完成奇迹之冠",
      "description": "完成奇迹之冠搭配赛，奇迹之冠巅峰赛",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    },
    {
      "id": "nikki.xinghai_run",
      "name": "收集星光结晶",
      "description": "收集星光结晶",
      "input_schema": { "type": "object", "properties": {}, "required": [] },
      "output_schema": { "type": "object", "properties": { "status": { "type": "string" }, "message": { "type": "string" }, "data": {} } }
    }
  ]
}
