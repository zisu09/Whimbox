{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "whimbox-core-rpc-schema",
  "title": "Whimbox Core JSON-RPC Schema",
  "type": "object",
  "$defs": {
    "JsonRpcBase": {
      "type": "object",
      "required": ["jsonrpc", "method"],
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "method": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "JsonRpcRequest": {
      "allOf": [{ "$ref": "#/$defs/JsonRpcBase" }],
      "required": ["id"],
      "properties": {
        "id": { "type": ["string", "number"] },
        "params": { "type": ["object", "array", "null"] }
      }
    },
    "JsonRpcResponse": {
      "type": "object",
      "required": ["jsonrpc", "id"],
      "properties": {
        "jsonrpc": { "const": "2.0" },
        "id": { "type": ["string", "number"] },
        "result": {
          "type": ["object", "array", "string", "number", "boolean", "null"]
        },
        "error": { "$ref": "#/$defs/JsonRpcError" }
      },
      "oneOf": [{ "required": ["result"] }, { "required": ["error"] }]
    },
    "JsonRpcNotification": {
      "allOf": [{ "$ref": "#/$defs/JsonRpcBase" }],
      "properties": {
        "params": { "type": ["object", "array", "null"] }
      },
      "not": { "required": ["id"] }
    },
    "JsonRpcError": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "integer" },
        "message": { "type": "string" },
        "data": {
          "type": ["object", "array", "string", "number", "boolean", "null"]
        }
      }
    },
    "Session": {
      "type": "object",
      "required": ["session_id", "state", "created_at"],
      "properties": {
        "session_id": { "type": "string" },
        "name": { "type": "string" },
        "profile": { "type": "string" },
        "state": {
          "type": "string",
          "enum": ["IDLE", "RUNNING", "PAUSED", "ERROR", "CLOSED"]
        },
        "window_handle": { "type": ["integer", "null"] },
        "metadata": { "type": "object" },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "type": "object",
      "required": ["role", "message"],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["user", "assistant", "system", "tool"]
        },
        "message": { "type": "string" },
        "meta": {
          "type": "object",
          "properties": {
            "tools_used": { "type": "array", "items": { "type": "string" } },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          },
          "additionalProperties": true
        }
      }
    },
    "Tool": {
      "type": "object",
      "required": ["tool_id", "name"],
      "properties": {
        "tool_id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "input_schema": { "type": "object" },
        "output_schema": { "type": "object" }
      }
    },
    "Params_session_create": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "profile": { "type": "string", "default": "default" },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "Params_session_list": { "type": "object" },
    "Params_session_get": {
      "type": "object",
      "required": ["session_id"],
      "properties": {
        "session_id": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Params_session_close": {
      "type": "object",
      "required": ["session_id"],
      "properties": {
        "session_id": { "type": "string" }
      }
    },
    "Params_session_attach_window": {
      "type": "object",
      "required": ["session_id", "window_handle"],
      "properties": {
        "session_id": { "type": "string" },
        "window_handle": { "type": "integer" },
        "capture_mode": {
          "type": "string",
          "enum": ["dxgi", "gdi", "d3d", "auto"]
        }
      }
    },
    "Params_agent_send_message": {
      "type": "object",
      "required": ["session_id", "message"],
      "properties": {
        "session_id": { "type": "string" },
        "message": { "type": "string" }
      }
    },
    "Params_task_run": {
      "type": "object",
      "required": ["session_id", "task_type"],
      "properties": {
        "session_id": { "type": "string" },
        "task_type": { "type": "string" },
        "input": { "type": "object" }
      }
    },
    "Params_task_control": {
      "type": "object",
      "required": ["session_id"],
      "properties": {
        "session_id": { "type": "string" },
        "task_id": { "type": "string" }
      }
    },
    "Params_tool_list": { "type": "object" },
    "Params_tool_invoke": {
      "type": "object",
      "required": ["session_id", "tool_id", "input"],
      "properties": {
        "session_id": { "type": "string" },
        "tool_id": { "type": "string" },
        "input": { "type": "object" }
      }
    },
    "Result_session_create": {
      "type": "object",
      "required": ["session_id"],
      "properties": {
        "session_id": { "type": "string" }
      }
    },
    "Result_session_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/Session" }
    },
    "Result_session_get": { "$ref": "#/$defs/Session" },
    "Result_session_attach_window": {
      "type": "object",
      "required": ["ok"],
      "properties": { "ok": { "type": "boolean" } }
    },
    "Result_agent_send_message": {
      "type": "object",
      "properties": { "accepted": { "type": "boolean" } }
    },
    "Result_task_run": {
      "type": "object",
      "required": ["task_id"],
      "properties": { "task_id": { "type": "string" } }
    },
    "Result_tool_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/Tool" }
    },
    "Result_tool_invoke": {
      "type": "object",
      "properties": { "output": { "type": "object" } }
    },
    "Event_agent_message": {
      "type": "object",
      "required": ["session_id", "message"],
      "properties": {
        "session_id": { "type": "string" },
        "message": { "$ref": "#/$defs/Message" }
      }
    },
    "Event_task_progress": {
      "type": "object",
      "required": ["session_id", "task_id", "progress"],
      "properties": {
        "session_id": { "type": "string" },
        "task_id": { "type": "string" },
        "progress": { "type": "number", "minimum": 0, "maximum": 1 },
        "detail": { "type": "string" }
      }
    },
    "Event_action_executed": {
      "type": "object",
      "required": ["session_id", "action"],
      "properties": {
        "session_id": { "type": "string" },
        "action": { "type": "string" },
        "detail": { "type": "object" }
      }
    },
    "Event_error": {
      "type": "object",
      "required": ["session_id", "code", "message"],
      "properties": {
        "session_id": { "type": "string" },
        "code": { "type": "integer" },
        "message": { "type": "string" },
        "detail": { "type": "object" }
      }
    }
  }
}

